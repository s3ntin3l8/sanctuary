###############################################################################
# THE SANCTUARY — environment configuration
#
# Copy this file to .env and adjust as needed. Lines starting with # are
# comments; a commented `#KEY=value` line shows the built-in default.
#
# The file is split into two tiers:
#   BASIC    — the handful of settings most deployments actually set.
#   ADVANCED — power-user / optional flags. The defaults are fine for most;
#              change them only if you understand the trade-off.
###############################################################################


###############################################################################
# BASIC SETTINGS — most deployments set these
###############################################################################

# --- Server & Network ---
# Port the application will listen on.
PORT=8000
# Interface to bind to.
# WARNING: 0.0.0.0 exposes the app on all interfaces. Only use on an isolated/
# trusted network or behind a reverse proxy. Use 127.0.0.1 (default) to restrict
# to this machine only.
HOST=127.0.0.1
# Enable debug mode for detailed error pages and hot-reloading (local dev only).
DEBUG=False

# --- CORS ---
# Comma-separated list of allowed browser origins. Docker-network deployment is
# the primary target, so the defaults include the in-container host aliases.
# Behind a reverse proxy, lock this to your real HTTPS origin (e.g.
# https://sanctuary.example.com).
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://host.docker.internal:3000,http://host.docker.internal:8000

# --- Sessions & Secrets ---
# Secret used to HMAC-sign session cookies.
# REQUIRED when HOST is non-loopback or when DEBUG=False.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Fallback order: SESSION_SECRET -> SECRET_KEY -> "dev-session-key" (insecure;
# the last-resort default exists only so local dev boots — never ship with it).
#SESSION_SECRET=

# --- Authentication / Accounts ---
# Master switch. true (default) requires login. false = single-user dev mode:
# every request is auto-bound to the bootstrap admin, no login screen.
AUTH_ENABLED=true
# Allow self-service signup at /signup. Off by default; can also be toggled at
# runtime from the admin user-management screen.
AUTH_SIGNUP_ENABLED=false
# Optional code-driven first-admin provisioning (e.g. Ansible). FRESH DB ONLY:
# set BOTH to seed the primary admin once, when the database has no users. After
# setup these are inert — change the account from the UI. Leave unset to onboard
# the first admin via the one-time create-admin screen on first visit.
#BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#BOOTSTRAP_ADMIN_PASSWORD=

# --- Database & Storage ---
# Credentials for the bundled Postgres `db` service (docker-compose.yml and
# docker-compose.traefik.yml both read these). Change them before exposing the
# database beyond your local machine.
POSTGRES_USER=sanctuary
POSTGRES_PASSWORD=sanctuary
POSTGRES_DB=sanctuary
# SQLAlchemy connection string, built from the credentials above. `make db-up`
# starts a local Postgres+pgvector container matching these defaults (see
# docker-compose.yml). Docker Compose overrides the host to `db` automatically
# — this `localhost` form is for running the app directly on the host machine.
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# --- AI / LLM ---
# Inference server base URL (Ollama, LMStudio, or any OpenAI-compatible API).
#AI_BASE_URL=http://127.0.0.1:11434
# Provider type: ollama | lmstudio | openai | auto
#AI_PROVIDER=ollama
# API key — leave as-is for local providers, set for OpenAI/cloud.
#AI_API_KEY=not-needed
# Model used for document summarisation, enrichment, and slicing.
#AI_SUMMARY_MODEL=qwen3.5:9b
# Embedding model for vector search. Dimension must match AI_EMBED_DIM.
#AI_EMBED_MODEL=nomic-embed-text:v1.5
# Embedding vector size. Must match the embed model's output dimension.
#AI_EMBED_DIM=768

# --- Background Tasks ---
# Set to "true" to run tasks synchronously in-process (no Redis needed; dev only).
# Set to "false" (default) for async task execution — requires REDIS_URL.
CELERY_TASK_ALWAYS_EAGER=false
# Redis connection string used as the Celery broker and result backend.
#REDIS_URL=redis://localhost:6379/0

# --- Localisation ---
# IANA timezone name for display and log timestamps.
# Overrideable at runtime via Settings → Appearance.
TIMEZONE=Europe/Berlin


###############################################################################
# ADVANCED SETTINGS — defaults are fine for most; change only if you know why
###############################################################################

# --- Logging ---
# Logging level (debug, info, warning, error, critical).
LOG_LEVEL=info
# Set to "0" to disable the rotating log file (e.g. in tests or containers).
# When enabled, logs are written to scratch/sanctuary.log (10 MB max, 5 backups).
#SANCTUARY_LOG_FILE=1

# --- Session tuning ---
# Signed-cookie session lifetime in seconds (default 14 days).
#SESSION_LIFETIME_SECONDS=1209600
# Set to "true" to add the Secure flag to session cookies (requires HTTPS).
#SESSION_COOKIE_SECURE=false

# --- OIDC / SSO (optional) ---
# OIDC / authentik SSO. Active only when issuer + client id + secret are all set;
# otherwise the OIDC routes 404 and the login button hides.
#OIDC_ISSUER=https://authentik.example.com/application/o/sanctuary
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc/callback
#OIDC_SCOPES=openid email profile
#OIDC_PROVIDER_NAME=authentik

# --- AI tuning ---
# Read timeout in seconds for streaming AI calls. Local inference on long
# prompts can exceed 60s; 600s gives slow local models adequate headroom.
#AI_READ_TIMEOUT=600
# User context prepended to every AI system prompt. Describe yourself, your
# role, and your case situation so the AI always has background context.
# The UI setting at /settings/ai overrides this when set; this env value
# survives `make reset`.
#AI_USER_CONTEXT=

# --- Gmail OAuth (optional) ---
# Leave all three empty (or unset) to disable Gmail ingestion.
#GMAIL_CLIENT_ID=
#GMAIL_CLIENT_SECRET=
#GMAIL_REDIRECT_URI=http://localhost:8000/api/ingest/gmail/oauth/callback

# --- Document Ingestion ---
# Timeout in seconds for PDF conversion tasks (Docling OCR can be slow).
#INGEST_CONVERSION_TIMEOUT=600
# How often the scan-folder watcher polls data/scans/incoming/ (seconds).
#SCAN_POLL_INTERVAL_SECONDS=30
# Minimum file age (seconds) before the scan watcher treats an incoming file as
# "settled" and starts processing it — guards against ingesting a half-written
# file that is still being copied in.
#SCAN_MTIME_GUARD_SECONDS=5

# --- Document Slicer ---
# Heuristic weights that control how multi-page PDFs are split into individual
# documents. Each weight (0–1) scales a signal; the threshold is the combined
# score above which a page boundary becomes a document split.
# Defaults are tuned for German legal correspondence — adjust only if the
# slicer splits incorrectly on your document types.
#SLICE_W_PAGE_RESET=0.30
#SLICE_W_LETTERHEAD=0.20
#SLICE_W_SALUTATION=0.20
#SLICE_W_BLANK=0.15
#SLICE_W_AZ_CHANGE=0.25
#SLICE_W_ENCLOSURE=0.30
#SLICE_W_DATE_LINE=0.25
#SLICE_HEURISTIC_THRESHOLD=0.35

# --- Internal (set automatically) ---
# Signals that code is running inside the app process. The Alembic env reads it
# to skip reconfiguring logging during in-app migrations. Leave as-is.
SANCTUARY_APP=1


###############################################################################
# TRAEFIK DEPLOYMENT — optional, only for docker-compose.traefik.yml
#
# A self-contained deployment profile that terminates HTTPS itself via Traefik
# + Let's Encrypt (see docker-compose.traefik.yml). Not used by the plain
# docker-compose.yml profile — leave commented out unless you're using it.
#
#   docker compose -f docker-compose.traefik.yml up -d
#
# In addition to the two variables below, also set for this profile:
#   CORS_ORIGINS=https://<your SANCTUARY_DOMAIN>
#   SESSION_COOKIE_SECURE=true      # Traefik terminates TLS; cookies need Secure
#   SESSION_SECRET=<generated>      # required behind a public proxy, see above
#   AI_BASE_URL=http://host.docker.internal:11434   # to reach AI on the host
###############################################################################

# Public hostname Traefik routes to and requests a Let's Encrypt cert for.
#SANCTUARY_DOMAIN=sanctuary.example.com
# Email Let's Encrypt uses for the ACME account / expiry notices.
#ACME_EMAIL=you@example.com
