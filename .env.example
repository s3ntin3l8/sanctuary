#                                                                             #
#     ____  ___    _   ________________  ______    ______  __                 #
#    / __ \/   |  / | / / ____/_  __/ / / /   |  / __ \ \/ /                 #
#   / /_/ / /| | /  |/ / /     / / / / / / /| | / /_/ /\  /                  #
#  / ____/ ___ |/ /|  / /___  / / / /_/ / ___ |/ _, _/ / /                   #
# /_/   /_/  |_/_/ |_/\____/ /_/  \____/_/  |_/_/ |_| /_/                    #
#                                                                             #
#                       QUIET SANCTUARY CASE MANAGEMENT                       #
###############################################################################

# --- CORE APPLICATION ---
# Port the application will listen on
PORT=8000
# Interface to bind to (0.0.0.0 for Docker/external access)
HOST=0.0.0.0
# Enable debug mode for detailed error pages and hot-reloading
DEBUG=True
# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info
# Flag to signal that we are running inside the app (used by migrations)
SANCTUARY_APP=1

# --- DATABASE & STORAGE ---
# SQLAlchemy connection string (Default is local SQLite)
DATABASE_URL=sqlite:///./data/sanctuary.db

# --- LOCAL AI (OLLAMA / LM STUDIO) ---
# The backend provider to use (ollama, lmstudio, openai, or auto)
AI_PROVIDER=ollama

# Base URL for the AI API
# Ollama default: http://127.0.0.1:11434
# LM Studio default: http://127.0.0.1:1234
AI_BASE_URL=http://127.0.0.1:11434

# API Key (required for some providers, not-needed for local Ollama/LM Studio)
AI_API_KEY=not-needed

# The model used for generating semantic embeddings
AI_EMBED_MODEL=nomic-embed-text:v1.5

# The model used for legal case summaries
AI_SUMMARY_MODEL=qwen3.5-9b-16k:latest

# User context prepended to every AI system prompt — describe yourself, your role,
# and your case situation so the AI always has background context. The UI setting
# at /settings/ai overrides this when set; this env value survives `make reset`.
AI_USER_CONTEXT=

# --- CELERY / BACKGROUND TASKS ---
# Set to "true" to run tasks synchronously in-process (useful for local dev without Redis).
# Requires Redis (REDIS_URL) when set to "false" (the default for production correctness).
CELERY_TASK_ALWAYS_EAGER=false
REDIS_URL=redis://localhost:6379/0

# --- CORS (Cross-Origin Resource Sharing) ---
# Comma-separated list of allowed origins
# For Docker: http://host.docker.internal:8000,http://localhost:8000
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://host.docker.internal:3000,http://host.docker.internal:8000
