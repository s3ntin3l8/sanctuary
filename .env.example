#                                                                             #
#                       QUIET SANCTUARY CASE MANAGEMENT                       #
###############################################################################

# --- CORE APPLICATION ---
# Port the application will listen on
PORT=8000
# Interface to bind to (0.0.0.0 for Docker/external access)
HOST=0.0.0.0
# Enable debug mode for detailed error pages and hot-reloading
DEBUG=True

# --- DATABASE & STORAGE ---
# SQLAlchemy connection string (Default is local SQLite)
DATABASE_URL=sqlite:///./data/sanctuary.db

# --- LOCAL AI (OLLAMA) ---
# Base URL for the Ollama API
# For standard local installs: http://localhost:11434
# For internal Docker networks: http://ollama:11434
# For external/proxy access example: https://ollama.example.com
OLLAMA_BASE_URL=http://localhost:11434

# The model used for generating semantic embeddings (Hybrid Search)
OLLAMA_EMBED_MODEL=nomic-embed-text

# The model used for legal case summaries (3-bullet analysis)
OLLAMA_SUMMARY_MODEL=qwen3.5:9b
