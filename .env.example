#    / __ \/   |  / | / / ____/_  __/ / / /   |  / __ \ \/ /                 #
#   / /_/ / /| | /  |/ / /     / / / / / / /| | / /_/ /\  /                  #
#  / ____/ ___ |/ /|  / /___  / / / /_/ / ___ |/ _, _/ / /                   #
# /_/   /_/  |_/_/ |_/\____/ /_/  \____/_/  |_/_/ |_| /_/                    #
#                                                                             #
#                       QUIET SANCTUARY CASE MANAGEMENT                       #
###############################################################################

# --- CORE APPLICATION ---
# Port the application will listen on
PORT=8000
# Interface to bind to (0.0.0.0 for Docker/external access)
HOST=0.0.0.0
# Enable debug mode for detailed error pages and hot-reloading
DEBUG=True
# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=info
# Flag to signal that we are running inside the app (used by migrations)
SANCTUARY_APP=1

# --- DATABASE & STORAGE ---
# SQLAlchemy connection string (Default is local SQLite)
DATABASE_URL=sqlite:///./data/sanctuary.db

# --- CELERY / BACKGROUND TASKS ---
# Set to "true" to run tasks synchronously in-process (useful for local dev without Redis).
# Requires Redis (REDIS_URL) when set to "false" (the default for production correctness).
CELERY_TASK_ALWAYS_EAGER=false
REDIS_URL=redis://localhost:6379/0

# --- CORS (Cross-Origin Resource Sharing) ---
# Comma-separated list of allowed origins
# For Docker: http://host.docker.internal:8000,http://localhost:8000
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://host.docker.internal:3000,http://host.docker.internal:8000
