###############################################################################
# THE SANCTUARY — environment for the self-contained Traefik deployment
#
# Goes with docker-compose.traefik.yml. Copy to .env beside it:
#   cp .env.traefik.example .env
#   docker compose -f docker-compose.traefik.yml up -d
#
# This profile is production-hardened: HTTPS-only cookies, CORS locked to the
# real domain, login required. docker compose reads this .env both for app
# config (env_file) and for ${...} interpolation in the compose file.
###############################################################################

# --- Traefik / TLS (consumed by docker-compose.traefik.yml) ---
# Public hostname Traefik routes to and requests a Let's Encrypt cert for.
SANCTUARY_DOMAIN=sanctuary.example.com
# Email Let's Encrypt uses for the ACME account / expiry notices.
ACME_EMAIL=you@example.com

# --- Server ---
# Bind on all interfaces inside the container (Traefik is the only ingress).
HOST=0.0.0.0
PORT=8000
DEBUG=False

# --- Sessions & Secrets (REQUIRED behind a public proxy) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=CHANGE_ME
# Mark session cookies Secure — Traefik terminates TLS, clients always use HTTPS.
SESSION_COOKIE_SECURE=true

# --- Authentication / Accounts ---
AUTH_ENABLED=true
AUTH_SIGNUP_ENABLED=false
# First admin, created on a fresh DB. Set a password here or via the one-time
# create-admin screen on first visit.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#BOOTSTRAP_ADMIN_PASSWORD=

# --- CORS (lock to your HTTPS origin only) ---
CORS_ORIGINS=https://sanctuary.example.com

# --- Database & Background Tasks ---
DATABASE_URL=sqlite:///./data/sanctuary.db
# Service name on the internal compose network — do not change.
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- AI / LLM ---
# host.docker.internal reaches an Ollama/LMStudio server on the Docker host
# (compose maps it via extra_hosts). Use a service URL if AI runs in-cluster.
AI_BASE_URL=http://host.docker.internal:11434
AI_PROVIDER=ollama
AI_API_KEY=not-needed
AI_SUMMARY_MODEL=qwen3.5:9b
AI_EMBED_MODEL=nomic-embed-text:v1.5
AI_EMBED_DIM=768

# --- OIDC / SSO (optional) ---
# Active only when issuer + client id + secret are all set. The redirect URI
# MUST be your HTTPS domain (Traefik terminates TLS, so use https://).
#OIDC_ISSUER=https://authentik.example.com/application/o/sanctuary
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_REDIRECT_URI=https://sanctuary.example.com/auth/oidc/callback
#OIDC_SCOPES=openid email profile
#OIDC_PROVIDER_NAME=authentik

# --- Localisation ---
TIMEZONE=Europe/Berlin

# --- Internal (set automatically) ---
SANCTUARY_APP=1
